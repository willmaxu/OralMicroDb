##site_group
data5 <- data4 %>%
  mutate(
    site_whole = trimws(site_whole),
    site_all = case_when(
      site_whole == "Saliva" ~ "Saliva",
      site_whole %in% c("Dental plaque","Subgingival plaque","Supragingival plaque","Impant plaque") ~ "Dental plaque",
      site_whole %in% c("Gingival","Gingival crevicular fluid","Periodontal pockets") ~ "Periodontal_related",
      site_whole %in% c("Oral mucosa","Buccal","Floor of mouth","Palate","Tongue") ~ "Oral mucosa",
      site_whole %in% c("Calculus","Intracanal","Oral rinse","Oral swab") ~ "Oral other_related",
      site_whole %in% c("Oral tumor-adjacent tissue","Oral tumor tissue") ~ "Oral tumor_related",
      site_whole %in% c("Gastrointestinal","Gastrointestinal fluid","Stool") ~ "Digestive_related",
      site_whole %in% c("Bronchial alveolar lavage fluid","Nasal","Nasopharyngeal","Oropharyngeal","Respiratory","Sputum") ~ "Respiratory_related",
      site_whole %in% c("Breast milk","Placenta","Reproductive tract","Semen","Urine","Vagina") ~ "Reproductive_related",
      site_whole %in% c("Tumor tissue","Tumor-adjacent tissue","Breast tissue") ~ "Tumor_related",
      site_whole %in% c("Carotid atherosclerotic plaque","Cyst fluid","Heart","Blood","Skin") ~ "Others",
      site_whole %in% c("Gloves","Water") ~ "Non_human",
      TRUE ~ site_whole
    )
  )

