##微生物含量表格
setwd("X:\\3/model/data1/merged_results/")
data1 <- read.delim(
  "merged_table.from_biom.txt",
  header       = TRUE,
  sep          = "\t",
  row.names    = 1,       # 第一列是 feature / OTU ID
  check.names  = FALSE,   # 保留原始样本名，不自动改
  comment.char = "",      # 不把 # 当注释号
  skip         = 1        # 跳过 "# Constructed from biom file" 那一行
)
head(data1, 10)

# 1) 只选数值列（防止有非数值列混进来）
num_cols <- vapply(data1, is.numeric, logical(1))
data_num <- data1[, num_cols, drop = FALSE]

# 2) 计算每个物种在所有样本中的总丰度
total_abund <- rowSums(data_num, na.rm = TRUE)

# （可选）如果你想排除某些行名，比如 Unassigned
# total_abund <- total_abund[!rownames(data_num) %in% c("Unassigned")]

# 3) 取总丰度 Top 10000 的物种名（行名）
n_top <- min(10000, length(total_abund))
top10000_taxa <- names(sort(total_abund, decreasing = TRUE))[seq_len(n_top)]

# top1000_taxa 就是你要的“前1000微生物种名字”
top10000_taxa[1:10]

top10000_df <- data.frame(
  taxa = top10000_taxa,
  total_abundance = total_abund[top10000_taxa],
  row.names = NULL
)

write.csv(top10000_df, "top10000_df.csv", row.names = T)

