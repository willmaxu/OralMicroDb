plot_alpha_box <- function(df, metric, y_lab = metric, out_prefix = "alpha_diversity") {
  
  df_metric <- df %>%
    filter(!is.na(agegroup), !is.na(.data[[metric]])) %>%
    mutate(
      agegroup = factor(agegroup, levels = age_levels),
      continent = factor(continent, levels = continent_levels)
    )
  
  p_all <- ggplot(df_metric, aes(x = agegroup, y = .data[[metric]],
                                 fill = agegroup, color = agegroup)) +
    geom_boxplot(
      width = 0.75,
      outlier.size = 0.6,
      outlier.alpha = 0.6,
      linewidth = 0.55
    ) +
    scale_fill_manual(values = age_colors) +
    scale_color_manual(values = border_colors) +
    labs(x = NULL, y = y_lab, title = "All") +
    theme_bw(base_size = 13) +
    theme(
      legend.position = "none",
      axis.text.x = element_text(angle = 45, hjust = 1),
      plot.title = element_text(hjust = 0.5, face = "bold", color = "white"),
      plot.background = element_rect(fill = "white", color = NA),
      panel.grid.major = element_blank(),
      panel.grid.minor = element_blank(),
      panel.border = element_rect(color = "black", fill = NA),
      strip.background = element_rect(fill = "#C95A0A", color = "black")
    )
  
  p_continent <- ggplot(df_metric, aes(x = agegroup, y = .data[[metric]],
                                       fill = agegroup, color = agegroup)) +
    geom_boxplot(
      width = 0.75,
      outlier.size = 0.45,
      outlier.alpha = 0.6,
      linewidth = 0.5
    ) +
    scale_fill_manual(values = age_colors) +
    scale_color_manual(values = border_colors) +
    facet_wrap2(
      ~ continent,
      ncol = 4,
      scales = "free_y",
      strip = strip_themed(
        background_x = elem_list_rect(fill = continent_strip_colors),
        text_x = elem_list_text(
          color = c("white", "black", "black", "black", "white", "black", "black"),
          face = "bold"
        )
      )
    ) +
    labs(x = NULL, y = y_lab) +
    theme_bw(base_size = 13) +
    theme(
      legend.position = "none",
      axis.text.x = element_text(angle = 45, hjust = 1),
      panel.grid.major = element_blank(),
      panel.grid.minor = element_blank(),
      panel.border = element_rect(color = "black", fill = NA)
    )
  
  ggsave(
    filename = paste0(out_prefix, "_All_", metric, ".pdf"),
    plot = p_all,
    width = 4,
    height = 4,
    useDingbats = FALSE
  )
  
  ggsave(
    filename = paste0(out_prefix, "_Continent_", metric, ".pdf"),
    plot = p_continent,
    width = 9,
    height = 5.5,
    useDingbats = FALSE
  )
  
  return(list(all = p_all, continent = p_continent))
}

